<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!--
    IIS configuration for RateExtract (Node.js via iisnode).
    Deployed under points.oneinsure.com.

    Prerequisites on the IIS server:
      1. Node.js LTS installed (PATH-accessible).
      2. iisnode module installed: https://github.com/Azure/iisnode/releases
         (download iisnode-full-v0.2.x-x64.msi).
      3. URL Rewrite Module: https://www.iis.net/downloads/microsoft/url-rewrite
      4. Application Pool: .NET CLR Version = "No Managed Code",
         Identity = a user with read/write access to the app folder and the
         uploads / logs subfolders. Recycling: every 6h is fine.

    Folder layout on the server (suggested):
      C:\inetpub\sites\points.oneinsure.com\
        ├── server.js
        ├── package.json
        ├── web.config       (this file)
        ├── node_modules\    (run `npm ci --omit=dev` on the box)
        ├── public\
        ├── routes\
        ├── parsers\
        ├── services\
        ├── config\
        ├── uploads\         (must be writable by app-pool identity)
        ├── exports\         (writable)
        └── iisnode\         (auto-created by iisnode for logs)
  -->
  <system.webServer>

    <!-- iisnode handler — runs server.js as the Node process. -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- URL Rewrite: everything except real files / iisnode-internal paths
         goes to server.js (Express handles routing). -->
    <rewrite>
      <rules>
        <!-- Don't rewrite iisnode's debugger UI -->
        <rule name="LogFile" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="iisnode" />
        </rule>

        <!-- Static files in /public, /uploads, /exports — let IIS serve. -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^(public|uploads|exports)/" />
          <action type="None" />
        </rule>

        <!-- Everything else → Node entry point. -->
        <rule name="NodeApp" patternSyntax="ECMAScript" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"  negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode settings — most defaults are fine; tune below if needed. -->
    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
      watchedFiles="*.js;web.config;package.json;config\**\*.json;parsers\**\*.js;services\**\*.js;routes\**\*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      devErrorsEnabled="false"
      maxRequestBufferSize="4194304"
      maxLogFileSizeInKB="1024"
      maxTotalLogFileSizeInKB="20480"
      maxLogFiles="10"
      flushResponse="false"
      enableXFF="true"
    />

    <!-- File upload size — multer accepts up to ~25 MB for big xlsx grids. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

    <!-- Mime-types for xlsx / pdf so static serving works correctly. -->
    <staticContent>
      <remove fileExtension=".xlsx" />
      <mimeMap fileExtension=".xlsx"
               mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
      <remove fileExtension=".pdf" />
      <mimeMap fileExtension=".pdf" mimeType="application/pdf" />
    </staticContent>

    <!-- Default doc fallback so visiting / renders the SPA. -->
    <defaultDocument>
      <files>
        <clear />
        <add value="server.js" />
      </files>
    </defaultDocument>

  </system.webServer>
</configuration>
