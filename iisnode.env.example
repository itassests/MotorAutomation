# Future Generali / RateExtract — environment variables
#
# Convert to a real .env file OR set these on the IIS Application Pool
# (Application Pool Identity must read them). Easiest is to define them
# as **machine-level** environment variables, then restart IIS so iisnode
# picks them up.
#
# IMPORTANT: do NOT commit a real .env file. This sample uses placeholder
# values only.

# ---------- Database (MSSQL) ----------
DB_HOST=10.0.0.10
DB_PORT=1433
DB_NAME=RateExtract
DB_USER=rateextract_app
DB_PASSWORD=********
DB_CONNECT_TIMEOUT=30000
DB_REQUEST_TIMEOUT=120000
DB_TRUST_CERT=true

# ---------- App ----------
# PORT is set automatically by iisnode — do NOT hard-code it here.
UPLOAD_DIR=D:\inetpub\sites\points.oneinsure.com\uploads

# ---------- Anthropic LLM enrichment (optional) ----------
# Leave blank to disable LLM-based remark parsing fallback.
ANTHROPIC_API_KEY=

# ---------- Beeinsured / Prarambh integrations (optional) ----------
BEEINSURED_DB_HOST=
BEEINSURED_DB_NAME=
BEEINSURED_DB_USER=
BEEINSURED_DB_PASSWORD=

PRARAMBH_DB_HOST=
PRARAMBH_DB_NAME=
PRARAMBH_DB_USER=
PRARAMBH_DB_PASSWORD=
