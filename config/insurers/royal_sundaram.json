          { "column": 4, "rate_type": "SATP_ACT", "segment": "Pvt Car >1500CC" },
          { "column": 5, "rate_type": "SATP_PACK", "segment": "Pvt Car <1000CC" },
          { "column": 6, "rate_type": "SATP_PACK", "segment": "Pvt Car 1000-1500CC" },
          { "column": 7, "rate_type": "SATP_PACK", "segment": "Pvt Car >1500CC" }
