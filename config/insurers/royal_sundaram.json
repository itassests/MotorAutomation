{
  "insurer": "royal_sundaram",
  "display_name": "Royal Sundaram General Insurance",
  "file_patterns": ["Effective From*", "Royal*", "RTO Master*", "*CV Grid*", "*Other than CV*"],

  "_v1_scope": [
    "Pan-India CV STP (state x tonnage)",
    "Private Car STP (RTO x CC band x ACT/PACK)",
    "TW STP (zone/state/city x bike/scooter)",
    "Tractor flat",
    "3W GCV Non-EV / EV (paired columns)",
    "4W GCV EV (FuelType x GVW x Type)",
    "RTO Master (5 LOB clusters: PvtCar, GCV, 3W PCV, Taxi, 2W)"
  ],
  "_phase2_pending": [
    "State-specific CV sheets (TN, MP, Punjab, CH&RJ, West UP, WB, Odisha, Bihar, AP, TS, East UP, JH, GJ, MH, KAR, ROI, ROI(2)) — multi-row banner with discount/make qualifiers",
    "PC Comp1 — multi-region pivot with discount bands",
    "PC Comp / 2w Comp — older comp grids",
    "PCV STP — wide pivot (multiple seating columns)",
    "Taxi Comp / School Bus / 3W PCV Comp / EV 3w Comp / EV STP",
    "New Car standalone make-CC-fuel-geo grid"
  ],

  "sheets": [
    {
      "name": "Pan India -CV STP",
      "name_pattern": "pan[\\s_-]*india.*cv[\\s_-]*stp|cv[\\s_-]*stp[\\s_-]*pan[\\s_-]*india",
      "layout": "flat_table",
      "product": "GCV",
      "config": {
        "header_row": 0,
        "data_start_row": 1,
        "column_map": {
          "remarks": 0,
          "region": 1
        },
        "rate_columns": [
          { "column": 2, "rate_type": "SATP", "segment": "GCV 0-2.3T" },
          { "column": 3, "rate_type": "SATP", "segment": "GCV 2.3-3.5T" },
          { "column": 4, "rate_type": "SATP", "segment": "GCV 3.5-7.5T" },
          { "column": 5, "rate_type": "SATP", "segment": "GCV 7.5-12T" },
          { "column": 6, "rate_type": "SATP", "segment": "GCV 12-20T" },
          { "column": 7, "rate_type": "SATP", "segment": "GCV 20-40T" },
          { "column": 8, "rate_type": "SATP", "segment": "GCV 40-45T" },
          { "column": 9, "rate_type": "SATP", "segment": "GCV >45T" }
        ],
        "decline_markers": ["IRDA", "NA", "D"],
        "skip_zero_rates": false
      }
    },

    {
      "name": "PC STP",
      "name_pattern": "^pc[\\s_]*stp$|pvt[\\s_]*car[\\s_]*stp",
