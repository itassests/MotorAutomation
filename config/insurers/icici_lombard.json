          { "column": 23, "rate_type": "Comp", "segment": "Tractor (Old)",                "applied_on": "Net", "vehicle_age_min": 1 },
          { "column": 24, "rate_type": "Comp", "segment": "PCV 3W Petrol/CNG (New)",      "applied_on": "Net", "fuel_type": "Petrol/CNG", "vehicle_age_min": 0, "vehicle_age_max": 0 },
          { "column": 25, "rate_type": "Comp", "segment": "PCV 3W Petrol/CNG (Old)",      "applied_on": "Net", "fuel_type": "Petrol/CNG", "vehicle_age_min": 1 },
          { "column": 26, "rate_type": "Comp", "segment": "PCV 3W Diesel",                "applied_on": "Net", "fuel_type": "Diesel" },
          { "column": 27, "rate_type": "Comp", "segment": "PCV 3W Electric",              "applied_on": "Net", "fuel_type": "Electric" },
          { "column": 28, "rate_type": "Comp", "segment": "School Bus <=18 Seater",       "applied_on": "Net" },
          { "column": 29, "rate_type": "Comp", "segment": "School Bus 18-36 Seater",      "applied_on": "Net" },
          { "column": 30, "rate_type": "Comp", "segment": "School Bus >36 Seater",        "applied_on": "Net" },
