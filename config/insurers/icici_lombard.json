      "file_pattern": "CV[\\s_]*GRID",
      "layout": "flat_table",
      "product": "GCV",
      "config": {
        "header_row": 0,
        "data_start_row": 1,
        "column_map": {
          "carrier_type": 0,
          "remarks": 1,
          "segment": 2,
          "make": 5,
          "model": 6,
          "region": 7,
          "fuel_type": 11,
          "sub_type": 12
        },
        "rate_columns": [
          { "column": 9, "rate_type": "Comp_CC_Call", "applied_on": "Net" }
        ],
        "decline_markers": ["NA", "N/A", "Inactive"]
