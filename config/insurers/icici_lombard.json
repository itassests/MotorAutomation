{
  "insurer": "icici_lombard",
  "display_name": "ICICI Lombard General Insurance",
  "file_patterns": ["*Pvt Car Grid*", "*CV GRID*", "*TW * Grid*", "*School Bus PO Grid*", "*RTO Code master*"],

  "_v1_scope": [
    "Pvt Car master grid (RTO category EMG/PMG x state/city x 13 product+fuel rate columns)",
    "TW grid (TW New 1+5 / TW Old / Annexure)",
    "CV master grid (CV_COMP + CV_AOTP)",
    "School Bus PO grid",
    "RTO Code master Vertical (GEO and Cluster)"
  ],

  "sheets": [
    {
      "name": "Sheet1",
      "_label": "Pvt Car Grid (single-sheet workbook)",
      "file_pattern": "Pvt[\\s_]*Car[\\s_]*Grid",
      "layout": "flat_table",
      "product": "CAR",
      "config": {
        "header_row": 1,
        "data_start_row": 2,
        "column_map": {
          "remarks": 1,
          "region": 1,
          "carrier_type": 0
        },
        "rate_columns": [
          { "column": 2,  "rate_type": "Comp_NEW_1+3",
            "segment": "Pvt Car New 1+3", "applied_on": "OD",
            "vehicle_age_min": 0, "vehicle_age_max": 0,
            "remarks": "[NEW]" },
          { "column": 2,  "rate_type": "Comp_NEW_3+3",
            "segment": "Pvt Car New 3+3", "applied_on": "OD",
            "vehicle_age_min": 0, "vehicle_age_max": 0,
            "remarks": "[NEW]" },

          { "column": 3,  "rate_type": "SAOD|NCB:GT0",
            "segment": "Pvt Car SAOD with NCB > 0% (3001/O, 3001/O2)",
            "applied_on": "OD", "fuel_type": "Petrol" },
          { "column": 4,  "rate_type": "SAOD|NCB:GT0",
            "segment": "Pvt Car SAOD with NCB > 0% (3001/O, 3001/O2)",
            "applied_on": "OD", "fuel_type": "CNG" },
          { "column": 5,  "rate_type": "SAOD|NCB:GT0",
            "segment": "Pvt Car SAOD with NCB > 0% (3001/O, 3001/O2)",
            "applied_on": "OD", "fuel_type": "Diesel" },
          { "column": 6,  "rate_type": "SAOD|NCB:GT0",
            "segment": "Pvt Car SAOD with NCB > 0% (3001/O, 3001/O2)",
            "applied_on": "OD", "fuel_type": "Electric" },

          { "column": 7,  "rate_type": "Comp|NCB:GT0",
            "segment": "Pvt Car Comprehensive with NCB > 0%",
            "applied_on": "OD", "fuel_type": "Petrol" },
          { "column": 8,  "rate_type": "Comp|NCB:GT0",
            "segment": "Pvt Car Comprehensive with NCB > 0%",
            "applied_on": "OD", "fuel_type": "CNG" },
          { "column": 9,  "rate_type": "Comp|NCB:GT0",
            "segment": "Pvt Car Comprehensive with NCB > 0%",
            "applied_on": "OD", "fuel_type": "Diesel" },
          { "column": 10, "rate_type": "Comp|NCB:GT0",
            "segment": "Pvt Car Comprehensive with NCB > 0%",
            "applied_on": "OD", "fuel_type": "Electric" },

          { "column": 11, "rate_type": "TP|NCB:No",
            "segment": "Pvt Car Act Only", "applied_on": "Net" },

          { "column": 12, "rate_type": "Comp|NCB:None",
            "segment": "Pvt Car Comp Non-NCB Renewal",
            "applied_on": "OD", "remarks": "[RENEWAL]" },
          { "column": 12, "rate_type": "Comp|NCB:None",
            "segment": "Pvt Car Comp Non-NCB Rollover",
            "applied_on": "OD", "remarks": "[ROLLOVER]" },
          { "column": 12, "rate_type": "SAOD|NCB:None",
            "segment": "Pvt Car SAOD Non-NCB Renewal",
            "applied_on": "OD", "remarks": "[RENEWAL]" },
          { "column": 12, "rate_type": "SAOD|NCB:None",
            "segment": "Pvt Car SAOD Non-NCB Rollover",
            "applied_on": "OD", "remarks": "[ROLLOVER]" },

          { "column": 13, "rate_type": "Comp_USED",
            "segment": "Pvt Car Used Car", "applied_on": "OD",
            "remarks": "[USED CAR]" },
          { "column": 13, "rate_type": "SAOD_USED",
            "segment": "Pvt Car Used Car", "applied_on": "OD",
            "remarks": "[USED CAR]" },
          { "column": 13, "rate_type": "TP_USED",
            "segment": "Pvt Car Used Car", "applied_on": "Net",
            "remarks": "[USED CAR]" }
        ],
        "decline_markers": ["NA", "D", "DECLINE"]
      }
    },

    {
      "name": "TW New 1+5",
      "name_pattern": "^tw[\\s_]*(?:new[\\s_]*)?1[+]5\\s*$",
      "file_pattern": "TW.*Grid",
      "layout": "flat_table",
      "product": "TW",
      "config": {
        "header_row": 1,
        "data_start_row": 2,
        "column_map": { "remarks": 1, "region": 1, "carrier_type": 0 },
        "rate_columns": [
          { "column": 2,  "rate_type": "Comp_NEW_1+5", "segment": "TW Bike (1+5) New",   "make": "Hero MotoCorp", "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 3,  "rate_type": "Comp_NEW_1+5", "segment": "TW Scooter (1+5) New","make": "Hero MotoCorp", "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 4,  "rate_type": "Comp_NEW_1+5", "segment": "TW Bike (1+5) New",   "make": "Honda",         "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 5,  "rate_type": "Comp_NEW_1+5", "segment": "TW Scooter (1+5) New","make": "Honda",         "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 6,  "rate_type": "Comp_NEW_1+5", "segment": "TW Bike (1+5) New",   "make": "Royal Enfield", "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 7,  "rate_type": "Comp_NEW_1+5", "segment": "TW Bike (1+5) New",   "make": "Suzuki",        "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 8,  "rate_type": "Comp_NEW_1+5", "segment": "TW Scooter (1+5) New","make": "Suzuki",        "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 9,  "rate_type": "Comp_NEW_1+5", "segment": "TW Bike (1+5) New",   "make": "TVS",           "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 10, "rate_type": "Comp_NEW_1+5", "segment": "TW Scooter (1+5) New","make": "TVS",           "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 11, "rate_type": "Comp_NEW_1+5", "segment": "TW Bike (1+5) New",   "make": "Yamaha",        "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 12, "rate_type": "Comp_NEW_1+5", "segment": "TW Scooter (1+5) New","make": "Yamaha",        "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" },
          { "column": 13, "rate_type": "Comp_NEW_1+5", "segment": "TW Bike & Scooter (1+5) Electric New", "fuel_type": "Electric", "applied_on": "OD", "vehicle_age_min": 0, "vehicle_age_max": 0, "remarks": "[NEW]" }
        ],
        "decline_markers": ["NA", "D", "DECLINE"],
        "annexure_lookup": {
          "sheet": "Annexure",
          "match": { "state_col": 1, "body_col": 2, "make_col": 3 },
          "rto_col": 5,
          "marker": "Refer Annexure"
        }
      }
    },

    {
      "name": "Sheet1",
      "_label": "ICICI CV Grid (April'26+ long-form: RTO | Cluster | Segment | PolicyType | MarRate | AprRate)",
      "name_pattern": "^Sheet1$",
      "file_pattern": "Final[\\s_]*CV[\\s_]*Grid|CV[\\s_]*Grid.*Apr|Apr.*CV[\\s_]*Grid",
      "layout": "flat_table",
      "product": "GCV",
      "config": {
        "header_row": 0,
        "data_start_row": 1,
        "column_map": {
          "carrier_type": 0,
          "region":       1,
          "segment":      2,
          "remarks":      3
        },
        "parse_conditional_cells": true,
        "rate_type_prefix_column": 3,
        "rate_columns": [
          { "column": 5, "rate_type": "Net", "applied_on": "Net" }
        ],
        "decline_markers": ["No Biz", "NoBiz", "CC", "NA", "N/A"]
      }
    },

